        <mxCell id="proto_box_contract" parent="lane_protocol" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;fontSize=14;" value="Why this layer exists&#xa;Keeps the execution/runtime contract sharable across crates instead of burying it in TUI or server code" vertex="1">
          <mxGeometry height="84" width="520" x="1110" y="74" as="geometry" />
