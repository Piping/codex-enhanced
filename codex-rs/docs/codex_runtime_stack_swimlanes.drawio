        <mxCell id="proto_box_server" parent="lane_protocol" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;fontSize=14;" value="`codex-app-server-protocol`&#xa;JSON-RPC request / response / notification schema for `thread/*`, `turn/*`, `command/*`" vertex="1">
          <mxGeometry height="84" width="520" x="540" y="74" as="geometry" />
