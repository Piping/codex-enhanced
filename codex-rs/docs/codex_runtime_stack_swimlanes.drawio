          <mxGeometry height="80" width="360" x="30" y="74" as="geometry" />
        </mxCell>
        <mxCell id="core_box_tasks" parent="lane_core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;fontSize=14;" value="Task orchestration&#xa;`Op` handling, user turns, review, compact, interrupts, realtime" vertex="1">
          <mxGeometry height="80" width="380" x="430" y="74" as="geometry" />
