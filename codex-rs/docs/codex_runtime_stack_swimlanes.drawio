        <mxCell id="proto_note" parent="lane_protocol" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;" value="Bottom line: protocol types are the vocabulary that lets TUI, core, and app-server compose without duplicating state models." vertex="1">
