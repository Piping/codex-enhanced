  <diagram id="codex-runtime-stack-swimlanes" name="Codex Runtime Stack Swimlanes">
    <mxGraphModel dx="1971" dy="836" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
