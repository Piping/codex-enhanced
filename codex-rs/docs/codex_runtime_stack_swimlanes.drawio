        <mxCell id="core_box_tools" parent="lane_core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;fontSize=14;" value="Tools and runtime policy&#xa;tool specs, handlers, approvals, sandboxing, shell, apply_patch" vertex="1">
          <mxGeometry height="80" width="420" x="850" y="74" as="geometry" />
        </mxCell>
        <mxCell id="core_box_clients" parent="lane_core" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;fontSize=14;" value="Model / client integration&#xa;responses client, reasoning stream, tool routing, event emission" vertex="1">
          <mxGeometry height="80" width="400" x="1310" y="74" as="geometry" />
        </mxCell>
        <mxCell id="core_note" parent="lane_core" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;" value="This is the real execution substrate. Both native TUI and app-server eventually converge here." vertex="1">
          <mxGeometry height="36" width="390" x="1180" as="geometry" />
        </mxCell>
        <mxCell id="lane_protocol" parent="1" style="swimlane;html=1;startSize=34;rounded=0;horizontal=1;collapsible=0;container=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" value="Protocol Layer" vertex="1">
