        <mxCell id="proto_box_internal" parent="lane_protocol" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d6b656;fontSize=14;" value="`codex-protocol`&#xa;Internal shared types: `Op`, `EventMsg`, `SessionSource`, `ThreadId`, `TurnItem`" vertex="1">
          <mxGeometry height="84" width="460" x="30" y="74" as="geometry" />
