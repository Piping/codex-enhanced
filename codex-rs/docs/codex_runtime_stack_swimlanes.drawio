        <mxCell id="title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" value="Codex Rust Workspace: TUI / App Server / Core / Protocol" vertex="1">
          <mxGeometry height="30" width="980" x="110" y="20" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;" value="Horizontal swimlanes show the main ownership boundaries. Native TUI can talk to core directly; richer clients can go through app-server." vertex="1">
          <mxGeometry height="20" width="1220" x="110" y="54" as="geometry" />
        </mxCell>
        <mxCell id="lane_tui" parent="1" style="swimlane;html=1;startSize=34;rounded=0;horizontal=1;collapsible=0;container=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" value="TUI Layer" vertex="1">
          <mxGeometry height="170" width="1870" x="110" y="110" as="geometry" />
        </mxCell>
        <mxCell id="tui_box_ui" parent="lane_tui" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;fontSize=14;" value="App + ChatWidget + BottomPane&#xa;Slash commands, key chords, popups, transcript rendering" vertex="1">
          <mxGeometry height="70" width="320" x="30" y="56" as="geometry" />
        </mxCell>
        <mxCell id="tui_box_events" parent="lane_tui" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;fontSize=14;" value="AppEvent loop&#xa;Routes UI intent into thread operations and local state changes" vertex="1">
          <mxGeometry height="70" width="320" x="390" y="56" as="geometry" />
        </mxCell>
        <mxCell id="tui_box_paths" parent="lane_tui" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;fontSize=14;" value="Frontend split&#xa;1. `tui` uses core directly&#xa;2. `tui_app_server` and IDE clients use app-server" vertex="1">
          <mxGeometry height="70" width="360" x="750" y="56" as="geometry" />
        </mxCell>
        <mxCell id="tui_note" parent="lane_tui" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;" value="Owns local interaction semantics: composer, overlays, menu trees, history presentation, and thread-local UX." vertex="1">
          <mxGeometry height="40" width="980" x="1150" as="geometry" />
        </mxCell>
        <mxCell id="lane_server" parent="1" style="swimlane;html=1;startSize=34;rounded=0;horizontal=1;collapsible=0;container=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" value="App Server Layer" vertex="1">
          <mxGeometry height="190" width="1870" x="110" y="320" as="geometry" />
        </mxCell>
        <mxCell id="server_box_transport" parent="lane_server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=14;" value="Transport&#xa;stdio / websocket&#xa;JSON-RPC framing and connection lifecycle" vertex="1">
          <mxGeometry height="80" width="290" x="30" y="64" as="geometry" />
        </mxCell>
        <mxCell id="server_box_processor" parent="lane_server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=14;" value="`codex_message_processor`&#xa;Maps RPC requests to core operations&#xa;Tracks subscriptions and emits notifications" vertex="1">
          <mxGeometry height="80" width="420" x="360" y="64" as="geometry" />
        </mxCell>
        <mxCell id="server_box_api" parent="lane_server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=14;" value="Thread / Turn / Command APIs&#xa;`thread/start`, `thread/resume`, `turn/start`, `command/exec`, config APIs" vertex="1">
          <mxGeometry height="80" width="430" x="820" y="64" as="geometry" />
        </mxCell>
        <mxCell id="server_box_notifications" parent="lane_server" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=14;" value="Notification fan-out&#xa;`thread/*`, `turn/*`, `item/*`, approval and MCP status updates" vertex="1">
          <mxGeometry height="80" width="380" x="1290" y="64" as="geometry" />
        </mxCell>
        <mxCell id="server_note" parent="lane_server" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;" value="Main purpose: provide a stable service boundary for rich clients without reimplementing core execution logic." vertex="1">
          <mxGeometry height="36" width="460" x="1190" as="geometry" />
        </mxCell>
        <mxCell id="lane_core" parent="1" style="swimlane;html=1;startSize=34;rounded=0;horizontal=1;collapsible=0;container=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" value="Core Layer" vertex="1">
